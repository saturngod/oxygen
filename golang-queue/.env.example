# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_KEY=oxygen-database-queues:transcode

# Worker
WORKER_CONCURRENCY=1
WORK_DIR=/tmp/transcoder

# Database (use DATABASE_URL or individual DB_* vars)
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=postgres
DB_PASSWORD=

# AWS (shared fallback for both source and streaming)
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Source bucket (overrides AWS_* above)
SOURCE_AWS_BUCKET=
SOURCE_AWS_ENDPOINT=
SOURCE_AWS_URL=
SOURCE_AWS_USE_PATH_STYLE_ENDPOINT=false

# Streaming bucket (overrides AWS_* above)
STREAMING_AWS_BUCKET=
STREAMING_AWS_ENDPOINT=
STREAMING_AWS_URL=
STREAMING_AWS_USE_PATH_STYLE_ENDPOINT=false
STREAMING_AWS_DEFAULT_REGION=

# FFmpeg
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FFMPEG_VIDEO_CODEC=libx264
PROGRESS_MIN_INTERVAL_MS=2000

# HLS output prefix inside the streaming bucket
HLS_PREFIX=hls
