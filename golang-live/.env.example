LIVE_ADDR=:8081
LIVE_HLS_ROOT=/tmp/oxygen-live/hls
LARAVEL_URL=http://127.0.0.1:8000
LIVE_SERVICE_TOKEN=
LIVE_CONTROL_TOKEN=
# Set to true ONLY for local dev to allow control requests when LIVE_CONTROL_TOKEN is empty.
# In production, leave false and set LIVE_CONTROL_TOKEN so the control plane is authenticated.
LIVE_ALLOW_INSECURE_CONTROL=false
VIEWER_TTL_SECONDS=45
ROLLUP_INTERVAL_SECONDS=15
